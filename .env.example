# ---- copy to .env and adjust; every value has a safe local default -------
TECHTREND_ENVIRONMENT=local

# Lake: local dir for dev/demo, s3://techtrend-lake for the Docker stack
TECHTREND_LAKE_ROOT=data/lake
TECHTREND_S3_ENDPOINT_URL=
TECHTREND_S3_ACCESS_KEY=
TECHTREND_S3_SECRET_KEY=

# Warehouse: duckdb (demo/CI) or postgres (Docker/cloud)
TECHTREND_WAREHOUSE_BACKEND=duckdb
TECHTREND_DUCKDB_PATH=data/warehouse/techtrend.duckdb
TECHTREND_POSTGRES_DSN=postgresql://techtrend:techtrend@localhost:5432/techtrend

# Ingestion: offline=true uses bundled samples (no network / keys needed)
TECHTREND_INGESTION_OFFLINE=true

# ML
TECHTREND_MLFLOW_TRACKING_URI=
TECHTREND_FORECAST_HORIZON_DAYS=14

# Kaggle (optional, for full-dataset ingestion)
KAGGLE_USERNAME=
KAGGLE_KEY=
