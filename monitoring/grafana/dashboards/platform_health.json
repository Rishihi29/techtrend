{
  "title": "TechTrend Platform Health",
  "uid": "techtrend-health",
  "timezone": "browser",
  "refresh": "30s",
  "panels": [
    {
      "title": "API request rate", "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "targets": [{"expr": "sum by (path) (rate(techtrend_http_requests_total[5m]))"}]
    },
    {
      "title": "API latency quantiles", "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "targets": [{"expr": "techtrend_http_latency_seconds"}]
    },
    {
      "title": "API 4xx/5xx rate", "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "targets": [{"expr": "sum by (status) (rate(techtrend_http_requests_total{status!~\"2..\"}[5m]))"}]
    },
    {
      "title": "Airflow task failures", "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
      "targets": [{"expr": "rate(airflow_ti_failures[15m])"}]
    },
    {
      "title": "Airflow DAG duration (s)", "type": "timeseries",
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 16},
      "targets": [{"expr": "airflow_dagrun_duration_success_sum / airflow_dagrun_duration_success_count"}]
    }
  ],
  "schemaVersion": 39
}
